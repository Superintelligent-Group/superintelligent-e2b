# =============================================================================
# E2B Self-Hosted — AWS Environment Template
# =============================================================================
# Copy to .env.dev (or .env.staging, .env.prod) and fill in values.
# Used by: make set-env ENV=dev && make init / make plan / make apply
# See iac/provider-aws/Makefile for how these map to TF_VAR_*
# =============================================================================

# ---- Required: AWS Account ----
AWS_ACCOUNT_ID=            # e.g., 319933937176
AWS_REGION=us-east-1       # Must support 8th-gen Intel (c8i) for nested virt
AWS_PROFILE=default        # AWS CLI profile name

# ---- Required: Domain ----
# Your domain or subdomain for E2B endpoints.
# Creates: api.{DOMAIN_NAME}, *.{DOMAIN_NAME} (for sandbox ports),
#          nomad.{DOMAIN_NAME} (Nomad UI)
DOMAIN_NAME=               # e.g., e2b.yourdomain.com

# ---- Required: Provider & Naming ----
PROVIDER=aws
PREFIX=e2b-                # Prefix for all AWS resources
BUCKET_PREFIX=             # e.g., e2b-319933937176- (usually PREFIX + ACCOUNT_ID + -)

# ---- Terraform ----
TERRAFORM_ENVIRONMENT=dev
TERRAFORM_STATE_BUCKET=    # e.g., e2b-sandbox-tfstate (S3 bucket for TF state)

# ---- Cluster Sizing ----
# Control server must always be 1. All others scale-to-zero via Lambda.
# Set initial sizes here; auto-scaling Lambda overrides at runtime.
CONTROL_SERVER_CLUSTER_SIZE=1    # Always 1 (Nomad + Consul servers)
API_CLUSTER_SIZE=1               # 1 = always on, 0 = scale-to-zero
CLIENT_CLUSTER_SIZE=0            # Sandbox runners (scaled by wake Lambda)
BUILD_CLUSTER_SIZE=0             # Template builders (scale manually when needed)
CLICKHOUSE_CLUSTER_SIZE=0        # 0 unless you need analytics
INGRESS_COUNT=1                  # Traefik replicas
CLIENT_PROXY_COUNT=1             # Sandbox port proxy replicas

# ---- Instance Types ----
# Control server: cheap, always-on
CONTROL_SERVER_MACHINE_TYPE=t3.medium

# API node: runs Traefik, API server, Redis, Postgres, OTEL
API_SERVER_MACHINE_TYPE=t3.large

# Client + Build nodes: run Firecracker VMs, MUST support nested virtualization.
# Only 8th-gen Intel (c8i, m8i, r8i and -flex variants) support nested KVM on AWS.
# See docs/instance-pricing.md for spot pricing comparison.
CLIENT_SERVER_MACHINE_TYPE=c8i.2xlarge
BUILD_SERVER_MACHINE_TYPE=c8i.2xlarge

# ---- Nested Virtualization ----
# MUST be true for client and build nodes (Firecracker requires KVM).
CLIENT_SERVER_NESTED_VIRTUALIZATION=true
BUILD_SERVER_NESTED_VIRTUALIZATION=true

# ---- Redis ----
# false = self-managed Redis via Nomad (cheaper for dev, ~$0)
# true  = AWS ElastiCache (recommended for prod, ~$13+/month)
REDIS_MANAGED=false

# ---- Database Connection Pool ----
DB_MAX_OPEN_CONNECTIONS=40
DB_MIN_IDLE_CONNECTIONS=5
AUTH_DB_MAX_OPEN_CONNECTIONS=20
AUTH_DB_MIN_IDLE_CONNECTIONS=5
