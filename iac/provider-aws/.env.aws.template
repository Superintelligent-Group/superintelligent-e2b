# =============================================================================
# E2B AWS Environment Configuration Template
# =============================================================================
# Copy this file to .env.aws.{environment} and fill in the values.
# e.g., .env.aws.prod, .env.aws.staging, .env.aws.dev
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
PREFIX="e2b-"  # Prefix identifier for all resources

# Environment: prod, staging, dev
TERRAFORM_ENVIRONMENT=prod

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Terraform State (created via state/ module)
TERRAFORM_STATE_BUCKET=e2b-terraform-state-CHANGEME
TERRAFORM_LOCK_TABLE=e2b-terraform-locks

# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------
VPC_CIDR=10.10.0.0/16

# Availability zones (minimum 2 recommended)
AVAILABILITY_ZONES=["us-east-1a","us-east-1b"]
PUBLIC_SUBNET_CIDRS=["10.10.0.0/24","10.10.1.0/24"]
PRIVATE_SUBNET_CIDRS=["10.10.10.0/24","10.10.11.0/24"]

# -----------------------------------------------------------------------------
# Domain & SSL
# -----------------------------------------------------------------------------
# Your domain for the E2B control plane (e.g., e2b.example.com)
DOMAIN_NAME=

# ACM Certificate ARN (must be in the same region as ALB)
ACM_CERTIFICATE_ARN=

# DNS Configuration (choose one):
# Option 1: Route 53
CREATE_ROUTE53_RECORD=false
ROUTE53_ZONE_ID=

# Option 2: Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# -----------------------------------------------------------------------------
# EC2 Instances
# -----------------------------------------------------------------------------
# Control Plane (API, Client Proxy, etc.)
CONTROL_PLANE_AMI_ID=  # Ubuntu 22.04 LTS AMI
CONTROL_PLANE_INSTANCE_TYPE=c6a.large
CONTROL_PLANE_MIN_SIZE=1
CONTROL_PLANE_DESIRED_CAPACITY=2
CONTROL_PLANE_MAX_SIZE=3

# Workers (Firecracker microVMs - must be Nitro-capable)
WORKER_AMI_ID=  # Ubuntu 22.04 LTS AMI (Nitro compatible)
WORKER_INSTANCE_TYPE=c6a.xlarge
WORKER_MIN_SIZE=1
WORKER_DESIRED_CAPACITY=2
WORKER_MAX_SIZE=5

# SSH Key (optional, for debugging)
SSH_KEY_NAME=

# Root volume size in GB
ROOT_VOLUME_SIZE=50

# -----------------------------------------------------------------------------
# Data Layer
# -----------------------------------------------------------------------------
# RDS PostgreSQL (set CREATE_RDS=false to use external database)
CREATE_RDS=true
RDS_INSTANCE_CLASS=db.t3.medium
RDS_ALLOCATED_STORAGE=20
RDS_MAX_ALLOCATED_STORAGE=100
RDS_POSTGRES_VERSION=15.4
RDS_DATABASE_NAME=e2b
RDS_USERNAME=e2b_admin
RDS_MULTI_AZ=false
RDS_BACKUP_RETENTION_DAYS=7

# External PostgreSQL (if CREATE_RDS=false)
# Format: postgresql://user:password@host:port/database
EXTERNAL_POSTGRES_CONNECTION_STRING=

# ElastiCache Redis (set CREATE_ELASTICACHE=false to use external Redis)
CREATE_ELASTICACHE=true
REDIS_NODE_TYPE=cache.t3.medium
REDIS_NUM_CACHE_CLUSTERS=2
REDIS_ENGINE_VERSION=7.0
REDIS_TRANSIT_ENCRYPTION=true
REDIS_AUTH_ENABLED=true

# External Redis (if CREATE_ELASTICACHE=false)
EXTERNAL_REDIS_URL=

# ClickHouse (must be provisioned externally)
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=e2b
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# -----------------------------------------------------------------------------
# S3 Buckets (leave empty for auto-generated names)
# -----------------------------------------------------------------------------
TEMPLATE_BUCKET_NAME=
SNAPSHOT_BUCKET_NAME=
BUILD_BUCKET_NAME=
LOG_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Secrets (will be stored in AWS Secrets Manager)
# -----------------------------------------------------------------------------
# Supabase JWT secrets for authentication
SUPABASE_JWT_SECRETS=

# PostHog analytics (optional)
POSTHOG_API_KEY=

# LaunchDarkly feature flags (optional)
LAUNCH_DARKLY_API_KEY=

# Analytics collector (optional)
ANALYTICS_COLLECTOR_HOST=
ANALYTICS_COLLECTOR_API_TOKEN=

# Sandbox access token seed (auto-generated if empty)
SANDBOX_ACCESS_TOKEN_HASH_SEED=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
CREATE_OBSERVABILITY=true
LOG_RETENTION_DAYS=30
ENABLE_ALB_ACCESS_LOGS=true
CREATE_ALARMS=true
ALARM_EMAIL=  # Email for alarm notifications

# -----------------------------------------------------------------------------
# Auto Scaling
# -----------------------------------------------------------------------------
ENABLE_AUTOSCALING_POLICIES=true
CONTROL_PLANE_SCALE_UP_THRESHOLD=70
CONTROL_PLANE_SCALE_DOWN_THRESHOLD=30
WORKER_SCALE_UP_THRESHOLD=60
WORKER_SCALE_DOWN_THRESHOLD=25

# -----------------------------------------------------------------------------
# Nomad/Consul Configuration
# -----------------------------------------------------------------------------
NOMAD_SERVER_COUNT=3
CONSUL_SERVER_COUNT=3

# Service ports
API_PORT=80
ORCHESTRATOR_PORT=5008
EDGE_PROXY_PORT=49982
EDGE_API_PORT=3001

# -----------------------------------------------------------------------------
# Docker Images (from ECR)
# -----------------------------------------------------------------------------
# These will be built and pushed via make build-and-upload
# Format: {account}.dkr.ecr.{region}.amazonaws.com/{repo}:{tag}
API_DOCKER_IMAGE=
DB_MIGRATOR_DOCKER_IMAGE=
CLIENT_PROXY_DOCKER_IMAGE=

# -----------------------------------------------------------------------------
# Integration Tests (optional)
# -----------------------------------------------------------------------------
TESTS_API_SERVER_URL=
TESTS_ORCHESTRATOR_HOST=
TESTS_ENVD_PROXY=
TESTS_SANDBOX_TEMPLATE_ID=base
TESTS_E2B_API_KEY=
TESTS_E2B_ACCESS_TOKEN=
TESTS_SANDBOX_USER_ID=
